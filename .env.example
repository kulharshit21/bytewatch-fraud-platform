APP_ENV=local
LOG_LEVEL=INFO
APP_VERSION=0.2.0

API_HOST=0.0.0.0
API_PORT=8000
PRODUCER_PORT=8001
STREAM_WORKER_PORT=8002
TRAINER_PORT=8003
ANALYST_CONSOLE_PORT=3001
MLFLOW_PORT=5000

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_RAW_TOPIC=tx.raw
KAFKA_VALIDATED_TOPIC=tx.validated
KAFKA_ENRICHED_TOPIC=tx.enriched
KAFKA_SCORED_TOPIC=tx.scored
KAFKA_DECISIONS_TOPIC=tx.decisions
KAFKA_FEEDBACK_TOPIC=tx.feedback
KAFKA_DLQ_TOPIC=tx.dlq

POSTGRES_DB=fraud_platform
POSTGRES_USER=fraud
POSTGRES_PASSWORD=fraud
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://fraud:fraud@postgres:5432/fraud_platform

REDIS_URL=redis://redis:6379/0

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_MODEL_NAME=fraud_xgboost
MLFLOW_CHAMPION_ALIAS=champion
MLFLOW_CHALLENGER_ALIAS=challenger

MODEL_LOCAL_CACHE_DIR=/tmp/fraud-platform-model-cache
MODEL_BLOCK_THRESHOLD=0.82
MODEL_REVIEW_THRESHOLD=0.55

PRODUCER_AUTOSTART=true
PRODUCER_RATE_PER_SECOND=3.0
PRODUCER_MAX_EVENTS=
PRODUCER_FRAUD_RATIO=0.18
PRODUCER_RANDOM_SEED=42
PRODUCER_EXPORT_PATH=/data/bootstrap_transactions.csv

FEATURE_WINDOW_1M_SECONDS=60
FEATURE_WINDOW_5M_SECONDS=300
FEATURE_WINDOW_1H_SECONDS=3600
FEATURE_PROFILE_TTL_SECONDS=2592000

RULES_CONFIG_PATH=/workspace/libs/rules/src/fraud_platform_rules/config/default_rules.yml
API_PUBLIC_BASE_URL=http://localhost:8000
API_INTERNAL_BASE_URL=http://api:8000

PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
